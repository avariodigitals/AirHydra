# Admin (server-only — never use NEXT_PUBLIC_ prefix for these)
ADMIN_PASSWORD=your-strong-password-here
ADMIN_KEY=your-strong-secret-key-here

# ImageKit
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-imagekit-id
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx

# Analytics (optional)
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
